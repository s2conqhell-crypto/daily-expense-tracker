rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: user owns this document via userId field
    function isOwner(resource) {
      return request.auth.uid == resource.data.userId;
    }
    // Helper: incoming data has correct userId
    function isOwnerIncoming() {
      return request.auth.uid == request.resource.data.userId;
    }
    // Helper: userId field cannot be changed on update
    function userIdUnchanged() {
      return request.resource.data.userId == resource.data.userId;
    }

    // User profiles - document ID is the userId
    match /users/{userId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    // Settings - document ID is the userId
    match /settings/{userId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    // Dashboard Layout - document ID is the userId
    match /dashboardLayout/{userId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    // Expense collections - ownership via userId field
    match /expenses/{docId} {
      allow read: if request.auth != null && isOwner(resource);
      allow create: if request.auth != null && isOwnerIncoming();
      allow update: if request.auth != null && isOwner(resource) && userIdUnchanged();
      allow delete: if request.auth != null && isOwner(resource);
    }

    match /income/{docId} {
      allow read: if request.auth != null && isOwner(resource);
      allow create: if request.auth != null && isOwnerIncoming();
      allow update: if request.auth != null && isOwner(resource) && userIdUnchanged();
      allow delete: if request.auth != null && isOwner(resource);
    }

    match /budgets/{docId} {
      allow read: if request.auth != null && isOwner(resource);
      allow create: if request.auth != null && isOwnerIncoming();
      allow update: if request.auth != null && isOwner(resource) && userIdUnchanged();
      allow delete: if request.auth != null && isOwner(resource);
    }

    match /savingGoals/{docId} {
      allow read: if request.auth != null && isOwner(resource);
      allow create: if request.auth != null && isOwnerIncoming();
      allow update: if request.auth != null && isOwner(resource) && userIdUnchanged();
      allow delete: if request.auth != null && isOwner(resource);
    }

    match /receipts/{docId} {
      allow read: if request.auth != null && isOwner(resource);
      allow create: if request.auth != null && isOwnerIncoming();
      allow update: if request.auth != null && isOwner(resource) && userIdUnchanged();
      allow delete: if request.auth != null && isOwner(resource);
    }

    match /notifications/{docId} {
      allow read: if request.auth != null && isOwner(resource);
      allow create: if request.auth != null && isOwnerIncoming();
      allow update: if request.auth != null && isOwner(resource) && userIdUnchanged();
      allow delete: if request.auth != null && isOwner(resource);
    }

    match /recurringTransactions/{docId} {
      allow read: if request.auth != null && isOwner(resource);
      allow create: if request.auth != null && isOwnerIncoming();
      allow update: if request.auth != null && isOwner(resource) && userIdUnchanged();
      allow delete: if request.auth != null && isOwner(resource);
    }

    match /subscriptions/{docId} {
      allow read: if request.auth != null && isOwner(resource);
      allow create: if request.auth != null && isOwnerIncoming();
      allow update: if request.auth != null && isOwner(resource) && userIdUnchanged();
      allow delete: if request.auth != null && isOwner(resource);
    }

    match /loans/{docId} {
      allow read: if request.auth != null && isOwner(resource);
      allow create: if request.auth != null && isOwnerIncoming();
      allow update: if request.auth != null && isOwner(resource) && userIdUnchanged();
      allow delete: if request.auth != null && isOwner(resource);
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
